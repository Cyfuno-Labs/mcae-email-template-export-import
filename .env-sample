# Salesforce MyDomain URL (e.g. https://yourorg.my.salesforce.com)
SF_URL=

# Salesforce External Client App (Consumer) Key
CLIENT_ID=

# Salesforce External Client App (Consumer) Secret
CLIENT_SECRET=

# Pardot Business Unit ID (18-character string, starts with 0Uv)
PARDOT_BUSINESS_UNIT_ID=

# Pardot Org Type: production, sandbox, or demo
PARDOT_ORG_TYPE=production
